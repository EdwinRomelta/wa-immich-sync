# ---- Immich connection (required) ----
# Base URL of your Immich server.
#   Local run:                 http://localhost:2283
#   Docker -> Immich on host:  http://host.docker.internal:2283
#   Docker -> Immich in Docker: http://<immich-service-name>:2283
IMMICH_URL=http://localhost:2283
# Immich -> Account Settings -> API Keys -> New API Key
IMMICH_API_KEY=your-immich-api-key

# ---- Which groups to sync (required) ----
# Comma-separated WhatsApp group NAMES or JIDs.
# Names are convenient; a JID (...@g.us) is stable across renames and unambiguous.
# Discover names/JIDs with: npm run list-groups
WHITELIST_GROUPS=Your Group Name, <group-jid>@g.us

# ---- Backfill via exported-chat zip (optional) ----
# Dedicated group: drop a WhatsApp "Export chat (with media)" .zip there and the
# bot imports every photo/video (album = the zip's caption, else the default).
BACKFILL_GROUP_NAME=wa-immich-backfill

# ---- Sync options (optional; defaults shown) ----
# per-group = one album per group | single = one album (SINGLE_ALBUM_NAME) | none
ALBUM_MODE=per-group
SINGLE_ALBUM_NAME=WhatsApp
# Comma-separated subset of: image,video
MEDIA_TYPES=image,video
# Request WhatsApp history sync on link (best-effort; only history since bot joined)
BACKFILL=true

# ---- Storage paths (optional; defaults shown) ----
WA_AUTH_DIR=./data/auth
DEDUP_DB=./data/synced.db

# Mark each synced message in WhatsApp with this emoji reaction.
# Unset/empty = off (no reaction). Set to an emoji to enable.
# SYNC_REACTION_EMOJI=🔄